{
	"name": "flux",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "tsx scripts/check_synthdefs.ts && NODE_OPTIONS=\"--import tsx\" vite dev",
		"build": "NODE_OPTIONS=\"--import tsx\" vite build",
		"build:synthdefs": "sclang scripts/compile_synthdefs.scd",
		"check:synthdefs": "tsx scripts/check_synthdefs.ts",
		"preview": "NODE_OPTIONS=\"--import tsx\" vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test:coverage": "vitest run --project server --coverage",
		"test": "npm run test:unit -- --run"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm lint-staged"
	},
	"lint-staged": {
		"*.{js,ts,svelte,svx,json,md,css,html}": "prettier --write"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^9.39.4",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^22.19.15",
		"@vitest/browser-playwright": "^4.1.2",
		"@vitest/coverage-v8": "^4.1.2",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"lint-staged": "^16.4.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"simple-git-hooks": "^2.13.1",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^7.3.1",
		"vite-plugin-monaco-editor": "^1.1.0",
		"vitest": "^4.1.2",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"@fontsource/inter": "^5.2.8",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"chevrotain": "^12.0.0",
		"monaco-editor": "^0.55.1"
	}
}
